# The digest/profile/personalize scripts are LLM-agnostic. Pick ONE provider.
# See scripts/llm.ts for the full list and defaults.

LLM_PROVIDER=anthropic        # anthropic | openai | google | groq | together | openrouter | mistral | deepseek | ollama | openai-compatible
# LLM_MODEL=                  # model id (defaults per provider if omitted)
# LLM_API_KEY=                # generic key (or use the provider's own var below)
# LLM_BASE_URL=               # override base URL (self-hosted / any OpenAI-compatible endpoint)

# Provider keys (only the one matching LLM_PROVIDER is needed):
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...          # or GOOGLE_API_KEY
# GROQ_API_KEY=...
# (ollama needs no key)

# --- digest tuning ---
# DIGEST_MAX_ITEMS=12
# DIGEST_PER_FEED=5

# --- email digest (npm run email) ---
# Provider-agnostic over SMTP. Without these it writes a preview to data/last-digest.html.
# SITE_URL=http://localhost:3000
# EMAIL_TO=you@example.com            # send here (skip the subscriber list — great for testing)
# EMAIL_FROM="The Daily AI <you@example.com>"
# EMAIL_HOST=smtp.gmail.com           # Gmail: use an App Password, port 587
# EMAIL_PORT=587
# EMAIL_USER=you@gmail.com
# EMAIL_PASS=your-app-password
# --- or Resend over SMTP ---
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=465
# EMAIL_USER=resend
# EMAIL_PASS=re_xxxxxxxx

# Examples:
#   LLM_PROVIDER=openai  OPENAI_API_KEY=sk-...  LLM_MODEL=gpt-4o-mini
#   LLM_PROVIDER=google  GEMINI_API_KEY=...     LLM_MODEL=gemini-2.0-flash
#   LLM_PROVIDER=ollama                         LLM_MODEL=llama3.1
