{
  "name": "the-daily-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "digest": "node --env-file=.env --import tsx scripts/generate-digest.ts",
    "profile": "node --env-file=.env --import tsx scripts/build-profile.ts",
    "personalize": "node --env-file=.env --import tsx scripts/personalize-edition.ts",
    "tune": "npm run profile && npm run personalize",
    "email": "node --env-file=.env --import tsx scripts/send-digest.ts"
  },
  "dependencies": {
    "@types/nodemailer": "^6.4.17",
    "next": "15.1.6",
    "nodemailer": "^6.9.16",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/node": "22.10.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "rss-parser": "3.13.0",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.2",
    "typescript": "5.7.3"
  }
}
